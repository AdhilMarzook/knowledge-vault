# ═══════════════════════════════════════════════════════════════════
#  KNOWLEDGE VAULT — Environment Variables
#  Copy to .env and fill in real values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Security (required) ─────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_DO_NOT_USE_THIS

# ── CORS: your frontend domain ──────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ── AI Providers (add at least ONE) ────────────────────────────────
#
# Priority order: Groq → Gemini → OpenRouter → Mistral → Claude
# The system automatically tries each in order and skips unconfigured ones.
# You only need ONE key to run the game — more = better resilience.
#
# ① Groq — FREE, fastest. Sign up: https://console.groq.com
GROQ_API_KEY=

# ② Google Gemini — FREE ~500 req/day. Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ③ OpenRouter — FREE models. Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# ④ Mistral — FREE (rate limited 2 req/min). Sign up: https://console.mistral.ai
MISTRAL_API_KEY=

# ⑤ Claude Haiku — PAID last resort (~$0.001/quest). Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=
